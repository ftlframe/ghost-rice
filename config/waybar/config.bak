{
  "layer": "bot",
  "spacing": 0,
  "height": 0,
  "margin-bottom": 0,
  "margin-top": 15,
  "position": "top",
  "margin-right": 500,
  "margin-left": 500,
  "modules-left": [
    "hyprland/workspaces",
    "sway/workspaces",
    "bluetooth",
    "custom/applauncher"

  ],
  "modules-center": [
    "mpris",
    "clock"
  ],
  "modules-right": [
    "sway/language",
    "network",
    "tray",
    "pulseaudio",
    "battery"
  ],
  "hyprland/workspaces": {
    "disable-scroll": true,
    "all-outputs": false,
    "tooltip": false
  },
  "sway/workspaces": {
    "disable-scroll": true,
    "all-outputs": false,
    "tooltip": false

  },
  "clock": {
    "disable-scroll": true,
    "format": "  {:%d.%m.%Y | %H:%M:%S}",
    "tooltip": true,
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
	"calendar": {
		"mode"          : "year",
		"mode-mon-col"  : 3,
		"weeks-pos"     : "right",
		"on-scroll"     : 1,
		"on-click-right": "mode",
		"format": {
			"months":     "<span color='#ffead3'><b>{}</b></span>",
			"days":       "<span color='#ecc6d9'><b>{}</b></span>",
			"weeks":      "<span color='#99ffdd'><b>W{}</b></span>",
			"weekdays":   "<span color='#ffcc66'><b>{}</b></span>",
			"today":      "<span color='#ff6699'><b><u>{}</u></b></span>"
		}
	},
    "interval": 1,
    "on-click": "gnome-calendar"
  },
  "bluetooth": {
    "disable-scroll": true,
    "all-outputs": false,
    "tooltip": false,
    "on-click": "blueman-manager"
  },
  "custom/applauncher": {
    "format": "",
    "on-click": "pgrep wofi >/dev/null 2>&1 && killall wofi || wofi --show drun --location=top -y 15",
    "tooltip": false
  },
  "tray": {
    "spacing": 10,
    "tooltip": false
  },
  "custom-date": {
    "format": "{:%a %-d }",
    "tooltip": false,
    "interval": 60,
    "on-click": "gnome-calendar"

  },
  "network": {
    "format-wifi": "",
    "format-ethernet": " ",
    "format-disconnected": " No Network",
    "interval": 5,
    "tooltip": false
  },
  "pulseaudio": {
    "scroll-step": 5,
    "max-volume": 150,
    "on-scroll-up": "pactl set-sink-volume @DEFAULT_SINK@ +5% && pactl set-sink-volume @DEFAULT_SINK@ 100% --",
    "on-scroll-down": "pactl set-sink-volume @DEFAULT_SINK@ -5%",
    "format": "{icon} {volume}%",
    "format-bluetooth": "{icon} {volume}%",
    "format-icons": [
      "",
      "",
      ""
    ],
    "nospacing": 1,
    "format-muted": "X",
    "on-click": "pavucontrol",
    "tooltip": false
  },
  "battery": {
    "format": "{icon} {capacity}%",
    "format-charging": " {capacity}%",   
    "format-plugged": " {capacity}%",      
    "format-alt": "{icon} {time}",
    "format-full": " {capacity}%",           
    "format-icons": ["", "", "", "", ""], 
    "states": {
        "warning": 20,
        "critical": 10
    },
    "interval": 10
  },
  "mpris": {
    "format": "{player_icon} {artist} - {title}",
    "format-paused": "{player_icon} {status_icon} {artist} - {title}",
    "player-icons": {
      "default": "▶"
    },
    "status-icons": {
      "paused": "⏸"
    },
    "max-length": 40,
    "on-click": "playerctl play-pause",
    "on-click-right": "playerctl next",
    "on-click-middle": "playerctl previous",
    "tooltip": false
  },
  "sway/language": {
    "format": " {}",
    "tooltip": false
  }
}
