[
  {
    "name": "topbar",
    "layer": "top",
    "position": "top",
    "exclusive": true,
    "fixed-center": true,
    "spacing": 2,
    "passthrough": false,
    "gtk-layer-shell": true,
    "reload_style_on_change": true,
    "modules-left": [
      "group/power",
      "clock",
      "network",
      "bluetooth"
    ],
    "modules-center": [],
    "modules-right": [
      "sway/language",
      "pulseaudio",
      "group/performance",
      "battery",
      "idle_inhibitor",
      "custom/dnd"
    ],
    "group/power": {
      "orientation": "inherit",
      "drawer": {
        "transition-duration": 500,
        "children-class": "drawer-child",
        "transition-left-to-right": true
      },
      "modules": [
        "custom/power",
        "custom/lock",
        "custom/logout"
      ]
    },
    "custom/power": {
      "format": "⏻",
      "tooltip": false,
      "on-click": "wlogout"
    },
    "custom/lock": {
      "format": "󰍁",
      "tooltip": false,
      "on-click": "swaylock -f"
    },
    "custom/logout": {
      "format": "󰍃",
      "tooltip": false,
      "on-click": "swaymsg exit"
    },
    "group/performance": {
      "orientation": "inherit",
      "drawer": {
        "transition-duration": 500,
        "children-class": "drawer-child",
        "transition-left-to-right": false
      },
      "modules": [
        "cpu",
        "memory"
      ]
    },
    "cpu": {
      "interval": 10,
      "format": "󰍛 {usage}%",
      "tooltip": false
    },
    "memory": {
      "interval": 30,
      "format": " {percentage}%",
      "format-alt": " {used:0.1f}G",
      "tooltip": true,
      "tooltip-format": "{used:0.1f}G / {total:0.1f}G"
    },
    "clock": {
      "interval": 1,
      "format": " {:%T    %d/%m/%Y}",
      "tooltip-format": "<tt><small>{calendar}</small></tt>",
      "calendar": {
        "mode": "month",
        "mode-mon-col": 1,
        "weeks-pos": "right",
        "on-scroll": 1,
        "on-click-right": "mode",
        "format": {
          "months": "<span color='#d4a8b8'><b>{}</b></span>",
          "days": "<span color='#c4bdd4'><b>{}</b></span>",
          "weeks": "<span color='#c4a87a'><b>W{}</b></span>",
          "weekdays": "<span color='#c4a87a'><b>{}</b></span>",
          "today": "<span color='#a899cc'><b><u>{}</u></b></span>"
        }
      },
      "on-click": "gnome-calendar"
    },
    "bluetooth": {
      "format": " {status}",
      "format-connected": " {device_alias}",
      "format-connected-battery": " {device_alias} {device_battery_percentage}%",
      "max-length": 14,
      "tooltip-format": "{controller_alias}\t{controller_address}\n\n{num_connections} connected",
      "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{num_connections} connected\n\n{device_enumerate}",
      "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
      "on-click": "blueman-manager"
    },
    "network": {
      "format-wifi": "{icon} [󰡨 {bandwidthTotalBytes}]",
      "format-ethernet": " [󰡨 {bandwidthTotalBytes}]",
      "format-disconnected": "⚠ disconnected",
      "format-alt": " {ipaddr}  {bandwidthUpBytes}  {bandwidthDownBytes}",
      "tooltip-format": "{ifname} via {gwaddr}",
      "tooltip-format-wifi": "{essid} {frequency}MHz ({signalStrength}%)",
      "tooltip-format-ethernet": "{ipaddr}/{cidr}",
      "interval": 5,
      "format-icons": [
        "󰤯",
        "󰤟",
        "󰤢",
        "󰤢",
        "󰤨"
      ]
    },
    "sway/language": {
      "format": " {short}"
    },
    "pulseaudio": {
      "scroll-step": 5,
      "max-volume": 150,
      "on-scroll-up": "pactl set-sink-volume @DEFAULT_SINK@ +5% && pactl set-sink-volume @DEFAULT_SINK@ 100% --",
      "on-scroll-down": "pactl set-sink-volume @DEFAULT_SINK@ -5%",
      "format": "{icon} {volume}%",
      "format-bluetooth": "{icon} {volume}%",
      "format-muted": "󰝟 muted",
      "format-icons": [
        "",
        "",
        ""
      ],
      "on-click": "pavucontrol",
      "tooltip": false
    },
    "battery": {
      "interval": 10,
      "states": {
        "good": 90,
        "warning": 20,
        "critical": 10
      },
      "format": "{icon} {capacity}%",
      "format-charging": " {capacity}%",
      "format-plugged": " {capacity}%",
      "format-alt": "{time} {icon}",
      "format-full": " {capacity}%",
      "format-icons": [
        "󰂎",
        "󰁺",
        "󰁻",
        "󰁼",
        "󰁽",
        "󰁾",
        "󰁿",
        "󰂀",
        "󰂁",
        "󰂂",
        "󰁹"
      ]
    },
    "idle_inhibitor": {
      "format": "{icon}",
      "format-icons": {
        "activated": "󰛨",
        "deactivated": "󰌶"
      },
      "tooltip": true,
      "tooltip-format-activated": "Idle inhibitor: ON",
      "tooltip-format-deactivated": "Idle inhibitor: OFF"
    },
    "custom/dnd": {
      "format": "{}",
      "exec": "swaync-client -D 2>/dev/null && echo '󰂛' || echo '󰂚'",
      "on-click": "swaync-client -t",
      "on-click-right": "swaync-client -d",
      "interval": 5,
      "tooltip": true,
      "tooltip-format": "Toggle notifications"
    }
  },
  {
    "name": "bottombar",
    "layer": "top",
    "position": "bottom",
    "height": 34,
    "exclusive": true,
    "fixed-center": true,
    "spacing": 2,
    "passthrough": false,
    "gtk-layer-shell": true,
    "reload_style_on_change": true,
    "modules-left": [
      "group/tray-hide",
      "custom/weather"
    ],
    "modules-center": [
      "sway/workspaces"
    ],
    "modules-right": [
      "custom/media",
      "custom/smallnc"
    ],
    "group/tray-hide": {
      "orientation": "inherit",
      "drawer": {
        "transition-duration": 500,
        "children-class": "drawer-child",
        "transition-left-to-right": true
      },
      "modules": [
        "custom/tray-hide",
        "tray"
      ]
    },
    "custom/tray-hide": {
      "format": "",
      "tooltip-format": "tray"
    },
    "tray": {
      "icon-size": 20,
      "spacing": 10
    },
    "sway/workspaces": {
      "disable-scroll": false,
      "all-outputs": false,
      "tooltip": false,
      "format": "{name}"
    },
    "custom/weather": {
      "format": "{}",
      "exec": "curl -s 'wttr.in/?format=%c+%t' | tr -d '+'",
      "interval": 900,
      "tooltip": false
    },
    "custom/smallnc": {
      "tooltip": false,
      "format": "󰂚",
      "on-click": "swaync-client -t",
      "on-click-right": "swaync-client -d"
    },
    "custom/media": {
      "format": "{}",
      "exec": "~/.config/waybar/mediaplayer.sh",
      "interval": 3,
      "max-length": 45,
      "on-click": "playerctl play-pause",
      "on-click-right": "playerctl next",
      "on-click-middle": "playerctl previous",
      "tooltip": false
    }
  }
]