# Dual monitor setup: Philips (left, HDMI-A-1, portrait) + Dell (right, DP-1, primary)
# Generated manually — or re-run setup-displays.sh to regenerate
output DP-1 pos 1080 0 res 1920x1080@239.761Hz
output HDMI-A-1 pos 0 0 res 1920x1080@179.998Hz transform 270

# Main monitor (Dell) gets 1-5
workspace 1 output DP-1
workspace 2 output DP-1
workspace 3 output DP-1
workspace 4 output DP-1
workspace 5 output DP-1
# Secondary monitor (Philips) gets 6-10
workspace 6 output HDMI-A-1
workspace 7 output HDMI-A-1
workspace 8 output HDMI-A-1
workspace 9 output HDMI-A-1
workspace 10 output HDMI-A-1
